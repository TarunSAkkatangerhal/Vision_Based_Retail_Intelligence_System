# ──────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.egg-info/
dist/
build/
*.egg

# ──────────────────────────────────────────────
# Virtual environments
# ──────────────────────────────────────────────
venv/
.venv/
env/
.env/

# ──────────────────────────────────────────────
# IDE / Editor
# ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ──────────────────────────────────────────────
# OS files
# ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ──────────────────────────────────────────────
# YOLO / Training artifacts
# ──────────────────────────────────────────────
runs/
wandb/
*.pt
*.task

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
*.db

# ──────────────────────────────────────────────
# Dataset images & videos (large files)
# ──────────────────────────────────────────────
dataset/images/train/*
dataset/images/val/*
dataset/labels/train/*
dataset/labels/val/*
dataset/sample_video.mp4

# Keep the folder structure
!dataset/images/train/.gitkeep
!dataset/images/val/.gitkeep
!dataset/labels/train/.gitkeep
!dataset/labels/val/.gitkeep

# ──────────────────────────────────────────────
# Video files
# ──────────────────────────────────────────────
video/*.mp4
video/*.avi
video/*.mov
video/*.mkv

# ──────────────────────────────────────────────
# Test images
# ──────────────────────────────────────────────
test_frame*.jpg
test_frame*.png

# ──────────────────────────────────────────────
# Windows reserved names
# ──────────────────────────────────────────────
nul

# ──────────────────────────────────────────────
# Logs / Misc
# ──────────────────────────────────────────────
*.log
.env
